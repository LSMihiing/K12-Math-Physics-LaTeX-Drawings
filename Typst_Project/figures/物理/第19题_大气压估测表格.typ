// ============================================================
// 第19题 · 大气压估测表格
// ============================================================

#let render() = {
  v(1em)

  align(center)[
    // 使用 Typst 原生的 table 引擎构建复杂表格
    #table(
      columns: (1.2fr, 2.5fr, 4.4fr, 1.9fr),
      align: (x, y) => {
        // 让第三列的简要步骤文字内容居左对齐，其它统统正中对齐
        if x == 2 and y > 0 {
          left + horizon
        } else {
          center + horizon
        }
      },
      stroke: 0.6pt + luma(80),
      // 表头和内容使用深浅不同的淡蓝色还原印刷真迹
      fill: (x, y) => if y == 0 { rgb("#CBEAFC") } else { rgb("#E6F7FE") },

      [实验方法], [所需器材], align(center)[操作的简要步骤], [计算大气压强的方法],

      [方法一],
      [吸盘挂钩、刻度尺、三角板、弹簧测力计、一块玻璃],
      [用刻度尺、三角板测量挂钩吸盘的直径 $D$；把挂钩按压在玻璃上；用弹簧测力计拉挂钩，读出刚要拉脱时的示数 $F$],
      [$p = frac(4F, pi D^2)$],

      [方法二],
      [注射器（带刻度）、刻度尺、弹簧测力计、细线、橡皮帽],
      [把注射器活塞推至底端排尽空气，用橡皮帽封住筒口小孔；用细线系住活塞，用弹簧测力计沿水平方向拉动活塞，记下刚滑动时的拉力 $F$；用刻度尺测出全部刻度部分的长度 $L$，记下容积 $V$],
      [$p = frac(F L, V)$],

      [方法三],
      [长约 $1 "m"$ 的一端封闭无色玻璃管、水银槽、水银、刻度尺],
      [将长玻璃管内灌满水银，用手指堵住管口倒立插入水银槽中，在水银面下放开手指；待液面稳定后，用刻度尺测出管内外水银面的垂直高度差 $h$],
      [$p = rho_"水银" g h$],
    )
  ]

  v(1.5em)

  // 绘图原理与步骤
  block(
    width: 100%,
    inset: (x: 1em, y: 0.8em),
    stroke: (left: 2.5pt + luma(140)),
    fill: luma(248),
    radius: 2pt,
  )[
    #text(weight: "bold", fill: luma(80), size: 11pt)[绘制原理与物理逻辑说明]
    #v(0.4em)

    - *物理实验理论补充*：除了原教材提供的方法一（吸盘法），初中物理中最经典的另两种估测/测量大气压强的规范方法分别为“注射器测大气压法”和“托里拆利实验法”。
    - *注射器法（方法二）推导*：利用受力平衡规律，活塞摩擦力忽略不计且刚滑动时拉力等于大气压力即 $F = p S$。由于注射器内部圆柱形横截面积 $S = V / L$（$V$为容积标定值，$L$为带刻度部分的总长度），代入公式并变换得到 $p = F/S = F L / V$。
    - *托里拆利实验法（方法三）推导*：此乃最绝对精准的实验。利用流体静力学平衡，管内高出槽面的支持水银柱所产生的液体压强精准等同于外界抗衡的大气压强，因此直接套用液体压强公式计算，即 $p = rho g h$。
    - *表格样式还原*：本题无须使用 `CeTZ` 绘图，直接启用了 Typst 内部极其强大的原生 `#table` 模块。通过设定按比例切割的 `columns` 来控制文字舒适度。更关键的是，通过动态着色函数 `fill: (col, row) => ...` 复刻了题干图片中，表头行的青蓝色（`#CBEAFC`）与普通内容行略显浅白的淡蓝色（`#E6F7FE`）相互搭配的印刷风格。
  ]
}
