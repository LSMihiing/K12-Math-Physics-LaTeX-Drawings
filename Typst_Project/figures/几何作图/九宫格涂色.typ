// ============================================================
// 九宫格分数涂色
// ============================================================

#import "@preview/cetz:0.4.2"

#let render() = {
  v(1em)

  align(center)[
    #cetz.canvas(length: 0.5cm, {
      import cetz.draw: *

      // 1. 基础配置与样式调色板
      let grid-color = rgb("#4FC3F7") // 青蓝色网格
      let grid-stroke = 0.8pt + grid-color
      let grid-dash = (paint: grid-color, thickness: 0.8pt, dash: (2.5pt, 2pt))
      
      let color-red = rgb("#FF0800")    // 原图中抢眼的大红色
      let color-green = rgb("#00FF55")  // 亮绿色
      let color-blue = rgb("#00D9FF")   // 青蓝（湖蓝）色

      // 2. 基底网格系统尺寸（经读图分析为 3列 x 3行 九宫格）
      let w = 2.0 // 扩增单格基准尺寸以便于清晰演示
      let cols = 3
      let rows = 3

      // 3. 逐列逐行定界并按指定占比涂色（核心逻辑区）
      // 画板坐标系设定：(0, 0) 为左下角
      
      // 区域A（红）：涂红色 5/9（覆盖第一行的全部3格 + 第二行的左侧2格）
      // 即 y 介于 2w 到 3w（顶层排）； y 介于 1w 到 2w, x 介于 0 到 2w（中层左侧）
      rect((0, 2 * w), (3 * w, 3 * w), fill: color-red, stroke: none)
      rect((0, 1 * w), (2 * w, 2 * w), fill: color-red, stroke: none)

      // 区域B（绿）：涂绿色 2/9（位于最底下左侧与中间横向连接的2格）
      // 即 y 介于 0 到 1w, x 介于 0 到 2w
      rect((0, 0), (2 * w, 1 * w), fill: color-green, stroke: none)

      // 区域C（蓝）：其余涂蓝色。9 - 5 - 2 = 2/9（右侧空闲的一列垂直方向的2格）
      // 即 y 介于 0 到 2w, x 介于 2w 到 3w
      rect((2 * w, 0), (3 * w, 2 * w), fill: color-blue, stroke: none)

      // 4. 在涂好的漆面上叠加基础网格标识线
      // 内部虚线切割
      for i in (1, 2) {
        line((i * w, 0), (i * w, rows * w), stroke: grid-dash)
        line((0, i * w), (cols * w, i * w), stroke: grid-dash)
      }
      // 外部实线轮廓锁边防溢出
      rect((0, 0), (cols * w, rows * w), stroke: grid-stroke)
    })
  ]

  v(1.5em)

  // 绘图原理与步骤（纯净化剥离）
  block(
    width: 100%,
    inset: (x: 1em, y: 0.8em),
    stroke: (left: 2.5pt + luma(140)),
    fill: luma(248),
    radius: 2pt,
  )[
    #text(weight: "bold", fill: luma(80), size: 11pt)[绘图原理与涂色组合步骤]
    #v(0.4em)
    
    - *等分拆解与底板构思*：题目核心依托于右侧标准 `3 * 3 = 9` 个面积均等的正方形网格体系（总分母定义为 $9$）。
    - *几何分配比例验证*：按题意要求红色占 $5/9$ （对应需要涂满任意 $5$ 个格子）；绿色占 $2/9$ （需要涂满任意 $2$ 个格子）；其余部分为蓝色涂装，通过数学减法推导出 $9 - 5 - 2 = 2$ ，即蓝色同样占据 $2$ 个格子（占 $2/9$份额）。这也完美呼应了下方填空小题第一问中的推演结果。
    - *模块化接驳色块*：为精确复刻参考解答给出的工整几何视觉排版，我们在 CeTZ 的作图域中分别拼装图块。第 1 步：将最高位整行划为红色（囊括 $3$ 格），外加中心位及其左侧（$2$ 格），无缝焊接成 $5$ 格体积的逆 L 形折角多边形。第 2 步：将右下角剥离出的狭长独立悬空两格连作*青蓝色域*（$2$ 格）。第 3 步：最下方剩余连贯的 $1 * 2$ 水平槽直接注满*亮绿色*（$2$ 格），此时所有的碎片严密咬合，填充满了全部图形域间隙。
    - *网格显化保护*：底层色料填实后会导致分界丢失，因此压轴操作利用 for 循环配合 `grid-dash` 参数把青蓝色致密分割虚线覆在画布顶部重新绘制，以此维系原方块被按格拆解的核心暗示效果。
  ]
}
