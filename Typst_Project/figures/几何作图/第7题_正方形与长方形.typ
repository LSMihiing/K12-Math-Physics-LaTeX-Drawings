// ============================================================
// 第7题 · 正方形与长方形作图及拼接
// ============================================================

#import "@preview/cetz:0.4.2"

// ==========================================
// 公共参数与样式
// ==========================================
#let block-stroke = 1.5pt + rgb("#0070C0") // 匹配原图的鲜明蓝色
#let label-size = 11pt

// ==========================================
// 题图定义
// ==========================================

// 图（1）：边长3厘米的正方形
#let figure-1 = cetz.canvas(length: 1cm, {
  import cetz.draw: *
  
  // 画正方形 3x3
  rect((0, 0), (3, 3), stroke: block-stroke)
  
  // 底部标记
  content((1.5, -0.4), [#text(size: label-size)[$3"cm"$]])
})

// 图（2）：长4厘米宽3厘米的长方形
#let figure-2 = cetz.canvas(length: 1cm, {
  import cetz.draw: *
  
  // 宽比长短1厘米，所以宽是 3
  // 画长方形 4x3
  rect((0, 0), (4, 3), stroke: block-stroke)
  
  // 底部标记长
  content((2, -0.4), [#text(size: label-size)[$4"cm"$]])
  // 右侧标记宽
  content((4.5, 1.5), [#text(size: label-size)[$3"cm"$]])
})

// ==========================================
// 输出：题目解答与组合图表
// ==========================================
#let render() = {
  set par(first-line-indent: 0em)

  // 解答块
  block(
    width: 100%,
    inset: (x: 1em, y: 0.8em),
    stroke: (left: 2.5pt + rgb("#4A90D9")),
    fill: rgb("#F0F6FF"),
    radius: 2pt,
  )[
    #text(weight: "bold", fill: rgb("#4A90D9"), size: 11pt)[解答]
    #v(0.4em)
    
    （1）直接绘制边长为 $3"cm"$ 的正方形。
    
    （2）已知长方形的长是 $4"cm"$，宽比长短 $1"cm"$，因此宽等于 $4 - 1 = 3"cm"$。需要绘制一个长 $4"cm"$、宽 $3"cm"$ 的长方形。
    
    （3）如果将这个正方形和这个长方形拼成一个大长方形：
    由于它们的宽（边长）均是 $3"cm"$，所以可以将它们由于宽度相等而无缝对齐拼接。
    拼接后的大长方形，其长为原正方形与长方形边长首尾相接之和，即 $3 + 4 = 7"cm"$；其宽度依然维持为 $3"cm"$。
    所以，大长方形长（ #text(fill: blue)[7] ）厘米，宽（ #text(fill: blue)[3] ）厘米。
  ]

  v(1.5em)

  // 图形绘制展示（脱离了背景框，保持清爽布局）
  align(center)[
    #grid(
      columns: 2,
      column-gutter: 6em,
      [
        #figure-1
        #v(0.8em)
        #text(size: 9pt, fill: luma(100))[（1）边长 $3$ 厘米的正方形]
      ],
      [
        #figure-2
        #v(0.8em)
        #text(size: 9pt, fill: luma(100))[（2）长 $4$ 宽 $3$ 的长方形]
      ]
    )
  ]

  v(1.5em)

  // 绘图原理与步骤
  block(
    width: 100%,
    inset: (x: 1em, y: 0.8em),
    stroke: (left: 2.5pt + luma(140)),
    fill: luma(248),
    radius: 2pt,
  )[
    #text(weight: "bold", fill: luma(80), size: 11pt)[绘图原理与步骤]
    #v(0.4em)
    
    - 真实比例：遵循“按比例与真实长度缩放”的要求，为画板配置了底层 `length: 1cm` 的基准。即在 Typst 渲染管线上 $1$ 个单位会被 1:1 输出到打印机纸面的 $1$ 厘米长度。
    - 生成正方形：生成 $3 times 3$ 的矩形，沿底边中位向下错开 $0.4$ 距离打印居中的 `3cm` 标签物料。
    - 生成长方形：基于宽比长少一厘而得出的尺寸，$x$ 轴扩展到 $4$，y 轴扩展到 $3$；右侧同样向外偏移标注出求出来的 `3cm` 宽。
    - 样式控制：通过剥离排版到独立位置，满足对 `作答背景块外纯净显示图形` 的最新格式要求。外框勾画颜色采样自参考图表的 `#0070C0`。
  ]
}
